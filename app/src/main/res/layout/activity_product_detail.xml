<?xml version="1.0" encoding="utf-8"?>
<!-- Detail activity layout: shows full product info in a scrollable view -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Product name - large header -->
        <TextView
            android:id="@+id/tvDetailName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginBottom="8dp"
            android:text="Product Name" />

        <!-- Divider line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="12dp" />

        <!-- Product ID label -->
        <TextView
            android:id="@+id/tvDetailId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#9E9E9E"
            android:layout_marginBottom="12dp"
            android:text="Product ID: 0" />

        <!-- Price with green styling -->
        <TextView
            android:id="@+id/tvDetailPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="22sp"
            android:textColor="#2E7D32"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"
            android:text="Price: $0.00" />

        <!-- Description section label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Description"
            android:textSize="14sp"
            android:textColor="#757575"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="6dp" />

        <!-- Full description text -->
        <TextView
            android:id="@+id/tvDetailDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="#424242"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="32dp"
            android:text="Full product description here." />

        <!-- Back to list button -->
        <Button
            android:id="@+id/btnBackToList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Back to List"
            android:backgroundTint="#1565C0"
            android:textColor="#FFFFFF"
            android:padding="14dp" />

    </LinearLayout>

</ScrollView>